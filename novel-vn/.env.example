# DeepSeek API Key
AI_DEEPSEEK_API_KEY=your_api_key_here

# Evolink Image API Key (for generating character avatars)
EVOLINK_API_KEY=your_api_key_here

# Data directory for SQLite database (default: ./data/)
DATA_DIR=./data

# Image storage directory (default: ./data/images/)
IMAGE_DIR=./data/images

# Session signing secret (change in production!)
SESSION_SECRET=your-random-secret-here
